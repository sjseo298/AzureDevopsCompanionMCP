{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "azure-devops": {
      "type": "local",
      "cwd": "/workspaces/AzureDevopsCompanionMCP",
      "command": [
        "/usr/bin/env",
        "bash",
        "/workspaces/AzureDevopsCompanionMCP/scripts/opencode-mcp-azure-devops.sh"
      ],
      "enabled": true,
      "timeout": 30000
    },
    "playwright": {
      "type": "local",
      "command": ["docker", "run", "-i", "--rm", "--network", "host", "--user", "root", "mcp/playwright"]
    }
  }
}
